{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "functions": {
    "api/staff-page.js": {
      "includeFiles": "creator.html"
    },
    "api/staff-manager-page.js": {
      "includeFiles": "manager.html"
    }
  },
  "rewrites": [
    {
      "source": "/staff",
      "destination": "/api/staff-page"
    },
    {
      "source": "/staff/",
      "destination": "/api/staff-page"
    },
    {
      "source": "/staff/manage",
      "destination": "/api/staff-manager-page"
    },
    {
      "source": "/staff/manage/",
      "destination": "/api/staff-manager-page"
    },
    {
      "source": "/creator.html",
      "destination": "/api/staff-page"
    },
    {
      "source": "/manager.html",
      "destination": "/api/staff-manager-page"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Referrer-Policy",
          "value": "no-referrer"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
